{
  "name": "lama-dev-portfolio-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "node -e \"const fs=require('fs');['.next','out'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "demos": "node scripts/generate-demos.mjs",
    "build:clean": "npm run demos && npm run clean && npm run build"
  },
  "dependencies": {
    "react": "18",
    "react-dom": "18",
    "next": "14.2.25",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.312.0"
  },
  "devDependencies": {
    "autoprefixer": "10.0.1",
    "postcss": "8",
    "tailwindcss": "3.3.0",
    "eslint": "8",
    "eslint-config-next": "14.1.0"
  }
}
